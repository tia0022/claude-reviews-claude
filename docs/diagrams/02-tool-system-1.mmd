graph TD
    ALL["getAllBaseTools()"] --> ALWAYS["Always Available"]
    ALL --> GATED["Feature-Gated"]
    ALL --> ENV["Environment-Gated"]

    subgraph sg_always["🟢 Always Available"]
        direction LR
        A1["BashTool"] --- A2["FileReadTool"] --- A3["FileEditTool"]
        A4["FileWriteTool"] --- A5["AgentTool"] --- A6["WebFetchTool"]
        A7["WebSearchTool"]
    end

    subgraph sg_gated["🟠 Feature-Gated"]
        direction LR
        G1["PROACTIVE → SleepTool"]
        G2["AGENT_TRIGGERS → CronCreate/Delete/List"]
        G3["MONITOR_TOOL → MonitorTool"]
        G4["KAIROS → SendUserFileTool, PushNotificationTool"]
        G5["COORDINATOR_MODE → coordinatorMode"]
        G6["HISTORY_SNIP → SnipTool"]
        G7["WEB_BROWSER_TOOL → WebBrowserTool"]
        G8["WORKFLOW_SCRIPTS → WorkflowTool"]
    end

    subgraph sg_env["🟣 Environment-Gated"]
        direction LR
        E1["USER_TYPE=ant → REPLTool, ConfigTool, TungstenTool"]
        E2["ENABLE_LSP_TOOL → LSPTool"]
        E3["NODE_ENV=test → TestingPermissionTool"]
    end

    ALWAYS --> sg_always
    GATED --> sg_gated
    ENV --> sg_env

    style ALWAYS fill:#27AE60,stroke:#333,color:#fff
    style GATED fill:#E67E22,stroke:#333,color:#fff
    style ENV fill:#8E44AD,stroke:#333,color:#fff